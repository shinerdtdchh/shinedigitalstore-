<?php
error_reporting(E_ALL & ~E_NOTICE & ~E_WARNING & ~E_DEPRECATED);
ini_set('display_errors', 0);

include('db.php');
session_start();
$error = "";
$success = "";

if (!isset($_SESSION['reg_step'])) {
    $_SESSION['reg_step'] = 1;
}

if (isset($_POST['back_to_1_btn']) || isset($_GET['back_step'])) { 
    $_SESSION['reg_step'] = 1; 
    unset($_SESSION['temp_reg']);
    header("Location: register.php");
    exit();
}

if (isset($_POST['send_otp_btn'])) {
    $email = isset($_POST['uemail']) ? trim($_POST['uemail']) : '';
    $email = strtolower($email);

    if (!filter_var($email, FILTER_VALIDATE_EMAIL)) {
        $error = "ကျေးဇူးပြု၍ တရားဝင်သော Email အစစ်အမှန်ကိုသာ ထည့်သွင်းပေးပါ။";
    } else {
        $allowed_domains = ['gmail.com', 'outlook.com', 'yahoo.com', 'hotmail.com', 'icloud.com'];
        $email_parts = explode('@', $email);
        $domain = end($email_parts);

        if (!in_array($domain, $allowed_domains)) {
            $error = "ကိုယ်ပိုင် Domain များဖြင့် ဖွင့်ခွင့်မရှိပါ။ gmail.com, outlook.com စသည့် နာမည်ကြီး Mail များကိုသာ သုံးပေးပါ။";
        } else {
            $check = cf_d1_query("SELECT username FROM users WHERE email='$email' LIMIT 1");
            if ($check && count($check) > 0) {
                $error = "ဤ Email သည် အသုံးပြုပြီးသား ဖြစ်နေပါသည်။";
            } else {
                $otp = rand(100000, 999999);
                $_SESSION['temp_reg'] = [
                    'email' => $email,
                    'otp' => $otp,
                    'otp_time' => time()
                ];
                send_verification_email($email, $otp);
                $_SESSION['reg_step'] = 2;
                $_SESSION['resend_locked_until'] = time() + 60;
                $success = "သင့် Mail သို့ OTP ကုဒ် ပို့လိုက်ပါပြီ။";
            }
        }
    }
}

if (isset($_POST['resend_otp_btn'])) {
    $temp = $_SESSION['temp_reg'];
    if (!empty($temp)) {
        $otp = rand(100000, 999999);
        $_SESSION['temp_reg']['otp'] = $otp;
        $_SESSION['temp_reg']['otp_time'] = time();
        $_SESSION['resend_locked_until'] = time() + 60;

        send_verification_email($temp['email'], $otp);
        $success = "OTP ကုဒ်အသစ်ကို Mail သို့ ပြန်လည်ပို့ပေးလိုက်ပါပြီ။";
    }
}

if (isset($_POST['verify_otp_btn'])) {
    $user_otp = trim($_POST['uotp']);
    $temp = $_SESSION['temp_reg'];

    if (empty($temp)) {
        $error = "စနစ်အမှားအယွင်း ဖြစ်သွားပါသည်။ အစမှ ပြန်လုပ်ပေးပါ။";
        $_SESSION['reg_step'] = 1;
    } else {
        if ((time() - $temp['otp_time']) > 600) {
            $error = "OTP ကုဒ်သည် သက်တမ်းကုန်ဆုံးသွားပါပြီ။";
            $_SESSION['reg_step'] = 1;
        } else if ($user_otp != $temp['otp']) {
            $error = "OTP ကုဒ် မှားယွင်းနေပါသည်။";
        } else {
            $_SESSION['reg_step'] = 3;
        }
    }
}

if (isset($_POST['final_register_btn'])) {
    $full_name = trim($_POST['full_name']);
    $username = trim($_POST['uname']);
    
    $username = str_replace('@', '', $username);
    $username = strtolower($username); 
    
    $dob = trim($_POST['udob']); 
    $password = trim($_POST['upass']);
    $cpassword = trim($_POST['ucpass']);
    $temp = $_SESSION['temp_reg'];

    if (empty($temp)) {
        $error = "စနစ်အမှားအယွင်း ဖြစ်သွားပါသည်။ အစမှ ပြန်လုပ်ပေးပါ။";
        $_SESSION['reg_step'] = 1;
    } else {
        $check_user = cf_d1_query("SELECT username FROM users WHERE username='$username' LIMIT 1");
        
        if ($check_user && count($check_user) > 0) {
            $error = "ဤ Username က အသုံးပြုပြီးသား ဖြစ်နေပါသည်။";
        } else if (strlen($password) < 8) {
            // Back-end Security Check
            $error = "လုံခြုံရေးအရ စကားဝှက်သည် အနည်းဆုံး ၈ လုံး ရှိရပါမည်။";
        } else if ($password !== $cpassword) {
            $error = "စကားဝှက်များ ကိုက်ညီမှု မရှိပါ။";
        } else {
            $id_code = rand(100000, 999999);
            $clean_pin = preg_replace('/[^0-9]/', '', $dob); 
            $auto_avatar = "https://api.dicebear.com/7.x/bottts/svg?seed=" . urlencode($username);
            
            $sql = "INSERT INTO users (full_name, username, password, email, pin, dob, profile_pic, user_id_code, role, balance, is_verified, otp_time) 
                    VALUES ('$full_name', '$username', '$password', '{$temp['email']}', '$clean_pin', '$dob', '$auto_avatar', '$id_code', 'user', 0, 1, {$temp['otp_time']})";
            
            cf_d1_query($sql);
            
            $_SESSION['username'] = $username;
            unset($_SESSION['temp_reg']);
            unset($_SESSION['reg_step']);
            unset($_SESSION['resend_locked_until']);
            
            header("Location: index.php");
            exit();
        }
    }
}
?>
