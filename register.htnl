                <!-- iOS WHEEL PICKER MODAL -->
                <div id="pickerDrawer" class="fixed inset-0 bg-black/60 z-50 hidden flex items-end transition-opacity duration-300 opacity-0">
                    <div class="w-full bg-slate-900 rounded-t-[2rem] p-6 space-y-4 transform translate-y-full transition-transform duration-300 max-w-sm mx-auto">
