                    <div>
                        <label class="text-[10px] text-slate-500 font-bold ml-2 uppercase tracking-wider">Birthday</label>
                        <input type="text" id="dob_trigger" readonly placeholder="Select Birthday" onclick="openPicker()" class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-4 mt-1 text-sm outline-none focus:border-blue-500 cursor-pointer text-blue-400 font-bold">
