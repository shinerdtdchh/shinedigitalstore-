            <!-- STEP 2 -->
            <?php elseif($_SESSION['reg_step'] == 2): ?>
                <input type="hidden" name="uotp" id="real_otp">
                <div class="space-y-6">
                    <div class="text-center">
                        <p class="text-[10px] text-blue-400 font-black mb-4 uppercase tracking-widest">Enter Verification OTP</p>
                        <div class="flex justify-center gap-2" id="otp-container">
                            <input type="number" autofocus class="otp-box w-12 h-14 bg-slate-950 border border-slate-800 text-center text-2xl font-black rounded-xl outline-none transition-all" pattern="[0-9]*" inputmode="numeric">
                            <input type="number" class="otp-box w-12 h-14 bg-slate-950 border border-slate-800 text-center text-2xl font-black rounded-xl outline-none transition-all" pattern="[0-9]*" inputmode="numeric">
                            <input type="number" class="otp-box w-12 h-14 bg-slate-950 border border-slate-800 text-center text-2xl font-black rounded-xl outline-none transition-all" pattern="[0-9]*" inputmode="numeric">
                            <input type="number" class="otp-box w-12 h-14 bg-slate-950 border border-slate-800 text-center text-2xl font-black rounded-xl outline-none transition-all" pattern="[0-9]*" inputmode="numeric">
                            <input type="number" class="otp-box w-12 h-14 bg-slate-950 border border-slate-800 text-center text-2xl font-black rounded-xl outline-none transition-all" pattern="[0-9]*" inputmode="numeric">
                            <input type="number" class="otp-box w-12 h-14 bg-slate-950 border border-slate-800 text-center text-2xl font-black rounded-xl outline-none transition-all" pattern="[0-9]*" inputmode="numeric">
                        </div>
                        
                        <button type="submit" name="verify_otp_btn" id="next_step_btn" class="w-full bg-blue-600 hover:bg-blue-500 py-3.5 rounded-2xl font-black text-xs uppercase tracking-widest text-white shadow-lg transition-all active:scale-[0.98] mt-6">
                            NEXT STEP ➡️
                        </button>

                        <div class="mt-5 pt-3 border-t border-slate-900">
                            <?php 
                            $seconds_left = isset($_SESSION['resend_locked_until']) ? $_SESSION['resend_locked_until'] - time() : 0;
                            if ($seconds_left > 0): 
                            ?>
                                <button type="button" id="resendBtn" disabled class="text-[11px] text-slate-600 font-bold uppercase tracking-wider cursor-not-allowed">
                                    🔄 Code ပြန်ပို့ရန် (<span id="countdown"><?php echo $seconds_left; ?></span>s)
                                </button>
                            <?php else: ?>
                                <button name="resend_otp_btn" id="resendBtn" class="text-[11px] text-blue-500 font-bold hover:underline uppercase tracking-wider">
                                    🔄 Code ပြန်ပို့ရန် (Resend OTP)
                                </button>
                            <?php endif; ?>
                        </div>
                    </div>
                </div>
                <script>
                    const inputs = document.querySelectorAll('#otp-container input');
                    const realOtp = document.getElementById('real_otp');
                    const nextBtn = document.getElementById('next_step_btn');

                    inputs.forEach((input, index) => {
                        input.addEventListener('input', (e) => {
                            if (input.value.length > 1) input.value = input.value.slice(0, 1);
                            if (input.value !== "" && index < inputs.length - 1) inputs[index + 1].focus();
                            collectOtp();
                        });
                        input.addEventListener('keydown', (e) => {
                            if (e.key === "Backspace" && input.value === "" && index > 0) inputs[index - 1].focus();
                        });
                    });

                    function collectOtp() {
                        let code = "";
                        inputs.forEach(input => code += input.value);
                        realOtp.value = code;
                        if (code.length === 6) {
                            nextBtn.click();
                        }
                    }

                    let seconds = <?php echo $seconds_left > 0 ? $seconds_left : 0; ?>;
                    if(seconds > 0) {
                        const interval = setInterval(() => {
                            seconds--;
                            document.getElementById('countdown').innerText = seconds;
                            if(seconds <= 0) {
                                clearInterval(interval);
                                const btn = document.getElementById('resendBtn');
                                btn.removeAttribute('disabled');
                                btn.name = "resend_otp_btn";
                                btn.type = "submit";
                                btn.className = "text-[11px] text-blue-500 font-bold hover:underline cursor-pointer";
                                btn.innerHTML = "🔄 Code ပြန်ပို့ရန် (Resend OTP)";
                            }
                        }, 1000);
                    }
                </script>

            <!-- STEP 3 -->
            <?php elseif($_SESSION['reg_step'] == 3): ?>
                <input type="hidden" name="udob" id="final_dob">
                <div class="space-y-4">
