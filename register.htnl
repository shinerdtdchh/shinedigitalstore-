                            <button type="button" onclick="confirmPicker()" class="text-xs text-blue-500 font-black uppercase tracking-wider">Done</button>
                        </div>
                        
                        <div class="relative flex justify-center items-center bg-slate-950 rounded-2xl p-2 border border-slate-800">
                            <div class="absolute inset-x-0 h-11 border-y border-blue-500/20 top-[68px] bg-blue-500/5"></div>
                            
                            <div class="picker-container w-1/3 text-center" id="monthWheel" onscroll="handleWheelScroll('monthWheel')">
                                <div class="h-[68px]"></div>
                                <?php for($m=1; $m<=12; $m++) echo "<div class='picker-item' data-val='".str_pad($m,2,'0',STR_PAD_LEFT)."'>".date('F', mktime(0,0,0,$m,1))."</div>"; ?>
                                <div class="h-[68px]"></div>
                            </div>
                            <div class="picker-container w-1/3 text-center" id="dayWheel" onscroll="handleWheelScroll('dayWheel')">
                                <div class="h-[68px]"></div>
                                <?php for($d=1; $d<=31; $d++) echo "<div class='picker-item' data-val='".str_pad($d,2,'0',STR_PAD_LEFT)."'>".str_pad($d,2,'0',STR_PAD_LEFT)."</div>"; ?>
                                <div class="h-[68px]"></div>
                            </div>
                            <div class="picker-container w-1/3 text-center" id="yearWheel" onscroll="handleWheelScroll('yearWheel')">
                                <div class="h-[68px]"></div>
                                <?php for($y=date('Y'); $y>=1950; $y--) echo "<div class='picker-item' data-val='$y'>$y</div>"; ?>
                                <div class="h-[68px]"></div>
                            </div>
                            <div class="absolute inset-0 picker-mask"></div>
                        </div>
                    </div>
                </div>

                <script>
                    function togglePasswordVisibility(inputId, btn) {
                        const input = document.getElementById(inputId);
                        if (input.type === "password") {
                            input.type = "text";
                            btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-blue-500"><path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" /></svg>`;
                        } else {
                            input.type = "password";
                            btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-slate-500"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.644r26.27A11.952 11.952 0 0012 20.3c3.41 0 6.51-1.422 8.77-3.707m0 0A11.95 11.95 0 0112 2.944a11.944 11.944 0 01-8.77 3.707M19.5 12a7.5 7.5 0 11-15 0 7.5 7.5 0 0115 0z" /></svg>`;
                        }
                    }

                    const unameInput = document.getElementById('uname_input');
                    if (unameInput) {
                        unameInput.addEventListener('input', (e) => {
                            let value = e.target.value.toLowerCase();
                            value = value.replace(/[^a-z0-9_]/g, '');
                            e.target.value = value;
                        });
                    }

                    // 💡 PASSWORD REAL-TIME & 8-CHARACTERS VALIDATOR
                    const passInput = document.getElementById('password_input');
                    const cpassInput = document.getElementById('cpassword_input');
                    const matchText = document.getElementById('password_match_text');
                    const submitBtnFinal = document.getElementById('final_submit_btn');

                    function checkPasswordsMatch() {
                        const pass = passInput.value;
                        const cpass = cpassInput.value;

                        // ၁။ အနည်းဆုံး ၈ လုံး ရှိမရှိ အရင်စစ်မည်
                        if (pass.length < 8) {
                            matchText.innerText = "❌ စကားဝှက်သည် အနည်းဆုံး ၈ လုံး ရှိရပါမည်";
                            matchText.className = "text-[11px] font-bold mt-1.5 ml-2 text-red-400";
                            submitBtnFinal.setAttribute('disabled', 'true');
                            return;
                        }

                        if (cpass.length === 0) {
                            matchText.innerText = "";
                            submitBtnFinal.removeAttribute('disabled');
                            return;
                        }

                        // ၂။ Password နှစ်ခု တူမတူ ဆက်စစ်မည်
                        if (pass === cpass) {
                            matchText.innerText = "✅ စကားဝှက်များ ကိုက်ညီပါသည်";
                            matchText.className = "text-[11px] font-bold mt-1.5 ml-2 text-emerald-400";
                            submitBtnFinal.removeAttribute('disabled');
                        } else {
                            matchText.innerText = "❌ စကားဝှက်များ မကိုက်ညီပါ";
                            matchText.className = "text-[11px] font-bold mt-1.5 ml-2 text-red-400";
                            submitBtnFinal.setAttribute('disabled', 'true');
                        }
                    }

                    passInput.addEventListener('input', checkPasswordsMatch);
                    cpassInput.addEventListener('input', checkPasswordsMatch);

                    // Wheel Picker
                    function openPicker() {
                        const drawer = document.getElementById('pickerDrawer');
                        drawer.classList.remove('hidden');
                        setTimeout(() => {
                            drawer.classList.add('opacity-100');
                            drawer.querySelector('.transform').classList.remove('translate-y-full');
                            updateSelectedClass('monthWheel'); updateSelectedClass('dayWheel'); updateSelectedClass('yearWheel');
                        }, 50);
                    }
                    function closePicker() {
                        const drawer = document.getElementById('pickerDrawer');
                        drawer.classList.remove('opacity-100');
                        drawer.querySelector('.transform').classList.add('translate-y-full');
                        setTimeout(() => drawer.classList.add('hidden'), 300);
                    }
                    function handleWheelScroll(id) {
                        clearTimeout(window[id + 'Timer']);
                        window[id + 'Timer'] = setTimeout(() => updateSelectedClass(id), 100);
                    }
                    function updateSelectedClass(id) {
                        const container = document.getElementById(id);
                        const centerIndex = Math.round(container.scrollTop / 45);
                        container.querySelectorAll('.picker-item').forEach((item, idx) => {
                            if (idx === centerIndex) item.classList.add('selected'); else item.classList.remove('selected');
                        });
                    }
                    function confirmPicker() {
                        const m = document.getElementById('monthWheel').querySelector('.selected').getAttribute('data-val');
                        const d = document.getElementById('dayWheel').querySelector('.selected').getAttribute('data-val');
                        const y = document.getElementById('yearWheel').querySelector('.selected').getAttribute('data-val');
                        document.getElementById('dob_trigger').value = `${m}-${d}-${y}`; 
                        document.getElementById('final_dob').value = `${y}-${m}-${d}`; 
                        closePicker();
                    }
                </script>
            <?php endif; ?>
        </form>
    </div>
</body>
</html>
